{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run TestUrlShortener",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++11",
                "TestUrlShortener.cpp",
                "../src/UrlShortener.cpp",
                "-o",
                "TestUrlShortener",
                "&&",
                "./TestUrlShortener"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}/backend/test"
            },
            "detail": "Compile and run TestUrlShortener with C++11 standard"
        }
    ]
}
